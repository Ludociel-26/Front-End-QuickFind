# =====================================================
# FRONTEND ENVIRONMENT VARIABLES (VITE)
# =====================================================
# ESTE ARCHIVO SÍ SE SUBE A GIT
# Es solo una plantilla de referencia.
# NO colocar credenciales ni valores sensibles aquí.
#
# Instrucciones:
# 1. Copiar este archivo a:
#    - .env.development (para desarrollo local)
#    - .env.production (para producción)
# 2. Reemplazar los valores según tu entorno.

# =====================================================
# BACKEND / API CONFIGURATION
# =====================================================
# URL base del backend (API)
# Ejemplos:
# Desarrollo:
# VITE_BACKEND_URL=http://localhost:3000
#
# Staging:
# VITE_BACKEND_URL=https://staging-api.tudominio.com
#
# Producción:
# VITE_BACKEND_URL=https://api.tudominio.com
#
VITE_BACKEND_URL=

# =====================================================
# APP ENVIRONMENT
# =====================================================
# Identificador del entorno de la aplicación
# Valores recomendados:
# development | staging | production
#
VITE_APP_ENV=development

# =====================================================
# API CONFIGURATION
# =====================================================
# Timeout global para peticiones HTTP (milisegundos)
# Ejemplo: 10000 = 10 segundos
#
VITE_API_TIMEOUT=10000

# =====================================================
# OPTIONAL - DEBUG & FEATURES
# =====================================================
# Activar logs de depuración en el frontend
# true | false
#
VITE_ENABLE_DEBUG=false

# =====================================================
# ⚠️ SEGURIDAD (MUY IMPORTANTE)
# =====================================================
# NUNCA agregar aquí:
# - JWT_SECRET
# - POSTGRES_URI
# - SMTP_PASS
# - API KEYS privadas
#
# Todo lo sensible debe estar SOLO en el backend (.env del API)
# porque las variables VITE_ se exponen en el navegador.
