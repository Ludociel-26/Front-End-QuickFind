# =========================
# FRONTEND CONFIG (VITE)
# =========================
# Entorno de ejecución del frontend
VITE_APP_ENV=development

# =========================
# BACKEND / API
# =========================
# URL base de tu Backend (API corre en puerto 3000)
VITE_BACKEND_URL=http://localhost:3000

# =========================
# API SETTINGS
# =========================
# Timeout global para peticiones HTTP (en milisegundos)
VITE_API_TIMEOUT=10000
